{
  "name": "@opentf/workeros-web",
  "version": "0.0.0",
  "description": "WorkerOS host runtime: kernel-worker + program-worker shims and the main-thread client API.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build:wasm": "wasm-pack build wasm --target web --out-dir ../src/kernel-wasm --release",
    "build:wasm:dev": "wasm-pack build wasm --target web --out-dir ../src/kernel-wasm --dev",
    "build": "npm run build:wasm",
    "build:programs": "node ../workeros-programs/tools/bundle.mjs",
    "build:coreutils": "node ../workeros-coreutils/tools/bundle.mjs",
    "build:bundles": "npm run build:programs && npm run build:coreutils",
    "preserve": "npm run build:bundles",
    "serve": "node tools/serve.js",
    "pretest": "npm run build:bundles",
    "test": "node --test tools/*.test.js",
    "compat:sync": "node tools/node-compat-sync.mjs",
    "test:node-compat": "node tools/node-compat-sync.mjs && node --test tools/node-compat.test.js",
    "test:node-compat:full": "node tools/node-compat-full.mjs && node tools/node-compat-report.mjs",
    "report:node-compat": "node tools/node-compat-report.mjs"
  },
  "devDependencies": {
    "playwright": "^1.48.0"
  }
}
